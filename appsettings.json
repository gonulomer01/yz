{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_DATABASE_SERVER,1433;Database=YOUR_DATABASE_NAME;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;Encrypt=True;MultipleActiveResultSets=true"
  },
  "SeleniumSettings": {
    "MaxConcurrentSessions": 3,
    "HeadlessMode": false
  },
  "DefaultAccountPassword": "YOUR_DEFAULT_ACCOUNT_PASSWORD",
  "Urls": "http://localhost:5000",
  "AllowedHosts": "*"
}
